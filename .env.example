# PostgreSQL 配置
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=5432

# GPU 配置 (根據需要設定)
# CUDA_VISIBLE_DEVICES=0 # 指定使用 GPU 0
# CUDA_VISIBLE_DEVICES=-1 # 強制使用 CPU
# CUDA_VISIBLE_DEVICES= # 讓 TensorFlow/Sionna 自動檢測 (預設行為)

# TF Log Level (可選)
# TF_CPP_MIN_LOG_LEVEL=3

# docker exec -it postgis_db psql -U sat -d sionna